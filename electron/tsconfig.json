{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "node16",
    "outDir": "../build",
    "noImplicitAny": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "rootDir": "..",
    "paths": {
      "*":["./node_modules/*"]
    }
  },
  "include": [
    "**/*",
    "../src/models/**/*",
    "../src/settings/**/*",
    "../src/theme/**/*",
    "../src/types/**/*",
    "../src/i18n/locales/**/*.json",
    "../src/utils/app-version/**/*",
    "../config/**/*"
  ]
}
