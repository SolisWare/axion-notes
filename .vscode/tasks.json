{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Desktop",
      "type": "npm",
      "script": "build:desktop",
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "Start Web Dev Server",
      "type": "npm",
      "script": "start:web",
      "options": {
        "env": {
          "BROWSER": "none"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting the development server",
          "endsPattern": "Compiled successfully|webpack compiled successfully"
        }
      }
    },
    {
      "label": "Prepare Electron Debug",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Start Web Dev Server",
        "Build Desktop"
      ],
      "problemMatcher": []
    }
  ]
}
