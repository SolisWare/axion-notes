{
  "compilerOptions": {
    "target": "es2019",
    "module": "Node16",
    "moduleResolution": "node16",
    "rootDir": "..",
    "outDir": "../build",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "../electron/utils/app-version/**/*.ts",
    "../src/utils/app-version/**/*.ts"
  ]
}
